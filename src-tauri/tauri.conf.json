{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antminer Fleet Manager",
  "version": "0.3.0",
  "identifier": "com.local.antminerfleet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Antminer Fleet Client",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/128x128.png", "icons/icon.ico"],
    "resources": [
      "../scripts/fleet-tunnel.ps1",
      "../scripts/openssh-bin/ssh.exe",
      "../scripts/openssh-bin/ssh-add.exe",
      "../scripts/openssh-bin/ssh-agent.exe",
      "../scripts/openssh-bin/ssh-keygen.exe",
      "../scripts/openssh-bin/ssh-keyscan.exe",
      "../scripts/openssh-bin/scp.exe",
      "../scripts/openssh-bin/sftp.exe",
      "../scripts/openssh-bin/ssh-pkcs11-helper.exe",
      "../scripts/openssh-bin/ssh-sk-helper.exe"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "installerHooks": "../scripts/install-openssh-client.nsh"
      }
    }
  }
}
