[Unit]
Description=Antminer Fleet Server reverse SSH tunnel
After=network-online.target antminer-fleet-server.service
Wants=network-online.target
PartOf=antminer-fleet-server.service

[Service]
Type=simple
User=antminer-fleet
Group=antminer-fleet
ExecStart=/usr/lib/antminer-fleet-server/run-reverse-tunnel.sh
Restart=always
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

[Install]
WantedBy=antminer-fleet-server.service
