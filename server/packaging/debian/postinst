#!/bin/sh
set -e

if ! getent group antminer-fleet >/dev/null; then
  addgroup --system antminer-fleet
fi
if ! getent passwd antminer-fleet >/dev/null; then
  adduser --system --ingroup antminer-fleet --home /var/lib/antminer-fleet --no-create-home antminer-fleet
fi

if ! getent group antminer-fleet-client-tunnel >/dev/null; then
  addgroup --system antminer-fleet-client-tunnel
fi
if ! getent passwd antminer-fleet-client-tunnel >/dev/null; then
  adduser --system --ingroup antminer-fleet-client-tunnel --home /var/lib/antminer-fleet-client-tunnel --no-create-home antminer-fleet-client-tunnel
fi

install -d -m 0750 -o antminer-fleet -g antminer-fleet /var/lib/antminer-fleet
install -d -m 0700 -o antminer-fleet -g antminer-fleet /var/lib/antminer-fleet/.ssh
install -d -m 0750 -o antminer-fleet-client-tunnel -g antminer-fleet-client-tunnel /var/lib/antminer-fleet-client-tunnel
install -d -m 0750 -o antminer-fleet-client-tunnel -g antminer-fleet-client-tunnel /etc/antminer-fleet/client-tunnel
if [ ! -f /etc/antminer-fleet/client-tunnel/authorized_keys ]; then
  install -m 0640 -o antminer-fleet-client-tunnel -g antminer-fleet-client-tunnel /dev/null /etc/antminer-fleet/client-tunnel/authorized_keys
fi

install -d -m 2750 -o root -g antminer-fleet /etc/antminer-fleet
install -d -m 2750 -o root -g antminer-fleet /etc/antminer-fleet/tls

if [ ! -f /etc/antminer-fleet/server.toml ]; then
  install -m 0640 -o root -g antminer-fleet /usr/share/doc/antminer-fleet-server/server.example.toml /etc/antminer-fleet/server.toml
fi

systemctl daemon-reload
echo "Edit /etc/antminer-fleet/server.toml, generate TLS, create the database, then enable the service."
echo "Optional reverse tunnel: install tunnel.conf and the SSH identity, then enable antminer-fleet-tunnel.service."
